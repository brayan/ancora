{
  "name": "@ancora/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "lint": "pnpm --silent run lint:naming && eslint .",
    "lint:naming": "node scripts/check-filename-case.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@ancora/config": "workspace:*",
    "@ancora/shared-types": "workspace:*",
    "@ancora/ui": "workspace:*",
    "@auth/drizzle-adapter": "^1.11.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.22.3",
    "typescript": "6.0.3"
  }
}
